<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="action_crm_activity" model="ir.actions.act_window">
        <field name="name">CRM Activities</field>
        <field name="res_model">crm.activity</field>
        <field name="view_mode">list,form</field>
    </record>
    <menuitem
        id="manu_crm_activity"
        name="CRM Activity"
        action="action_crm_activity"
        sequence="10"/>

    <record id="view_crm_activity_list" model="ir.ui.view">
        <field name="name">crm.activity.list</field>
        <field name="model">crm.activity</field>
        <field name="arch" type="xml">
        <list>
        <field name="partner_id"/>
        <field name="lead_id"/>
        <field name="user_id"/>
        <field name="activity_type"/>
        <field name="date_time"/>
        <field name="text"/>
        </list>
        </field>
    </record>

    <record id="view_crm_activity_form" model="ir.ui.view">
        <field name="name">crm.activity.form</field>
        <field name="model">crm.activity</field>
        <field name="arch" type="xml">
        <form>
            <group>
        <field name="partner_id"/>
        <field name="lead_id"/>
        <field name="activity_type"/>
        <field name="date_time"/>
        <field name="user_id"/>
        <field name="text"/>
            </group>
        </form>
        </field>
    </record>
</odoo>