<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_crm_lead_form_inherit_custom_activity" model="ir.ui.view">
        <field name="name">crm.lead.form.inherit.custom.activity</field>
        <field name="model">crm.lead</field>
        <field name="inherit_id" ref="crm.crm_lead_view_form"/>
        <field name="arch" type="xml">
        <xpath expr='//notebook' position="inside">
            <page string="Maxsus Faoliyatlar">
                <field name="custom_activity_ids" context="{'default_lead_id':id, 'default_partner_id':partner_id}">
                    <list editable="bottom">
                        <field name="activity_type"/>
                        <field name="date_time"/>
                        <field name="user_id"/>
                        <field name="text"/>
                    </list>
                </field>
            </page>
        </xpath>
      </field>


    </record>
</odoo>